# Ollama API base URL (must include scheme), e.g. https://ollama-api.damineweb.work
OLLAMA_API_BASE=https://example.com/ollama-api
# Model name to use (from /api/tags). Example: llama3.2:3b
OLLAMA_MODEL=llama3.2:3b
# Optional API key if your Ollama proxy requires it (leave blank if not needed)
OLLAMA_API_KEY=

# Behavior toggles
# AUTO_APPROVE_LOW_RISK=false
# AUTO_APPROVE_ALL=false